{
	"name": "hire-gnome-ats",
	"version": "1.5.1",
	"private": true,
	"license": "AGPL-3.0-only",
	"scripts": {
		"predev": "prisma generate",
		"dev": "NODE_ENV=development next dev",
		"db:up": "docker compose -f docker-compose.dev.yml up -d",
		"db:down": "docker compose -f docker-compose.dev.yml down",
		"db:logs": "docker compose -f docker-compose.dev.yml logs -f mysql",
		"db:reset": "docker compose -f docker-compose.dev.yml down -v",
		"prebuild": "node scripts/clean-next.js && prisma generate",
		"build": "NODE_ENV=production next build",
		"build:deploy": "NODE_ENV=production npx prisma migrate deploy && npm run build",
		"prestart": "prisma generate",
		"start": "NODE_ENV=production next start",
		"ci:preflight": "node scripts/preflight.cjs",
		"ci:build": "npm run build",
		"ci:smoke": "node scripts/test-permissions-api.cjs",
		"ci:test": "npm run ci:preflight && npm run ci:build",
		"test:permissions": "node scripts/test-permissions-api.cjs",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"bootstrap": "node scripts/bootstrap.js",
		"bootstrap:admin": "node scripts/provision-default-admin.js",
		"health": "node scripts/health-check.js",
		"db:backup": "node scripts/db-backup.js --output .backups",
		"db:backup:scheduled": "node scripts/db-backup-scheduled.js --output .backups",
		"db:restore": "node scripts/db-restore.js",
		"db:clear:operational": "node scripts/clear-operational-data-preserve-users.js",
		"storage:candidates:audit": "node scripts/local-storage-candidate-orphans.js",
		"storage:candidates:clean": "node scripts/local-storage-candidate-orphans.js --delete",
		"demo:seed": "node scripts/seed-dummy-data.js",
		"demo:reset": "node scripts/demo-reset.js --mode=full --preserve-settings=true",
		"demo:reset:seed-only": "node scripts/demo-reset.js --mode=seed --preserve-settings=true",
		"demo:reset:loop": "node scripts/demo-reset-loop.js"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1010.0",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@prisma/client": "^6.19.2",
		"exceljs": "^4.4.0",
		"jszip": "^3.10.1",
		"lucide-react": "^0.577.0",
		"mammoth": "^1.12.0",
		"mysql2": "^3.20.0",
		"next": "^16.1.7",
		"nodemailer": "^8.0.2",
		"pdf-parse": "^2.4.5",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"stripe": "^20.4.1",
		"word-extractor": "^1.0.4",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"prisma": "^6.19.2"
	}
}
