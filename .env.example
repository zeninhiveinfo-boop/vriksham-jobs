# Core runtime
# Prisma/MySQL connection string.
DATABASE_URL="mysql://root:password@localhost:3306/ats"
# Public app URL used for auth/reset links.
AUTH_APP_BASE_URL="http://localhost:3000"
# Session signing secret. Use a long random value in real environments.
AUTH_SESSION_SECRET="replace-with-a-long-random-secret"
# Optional dedicated secret for client-review portal magic links.
# If empty, the portal token signer falls back to AUTH_SESSION_SECRET.
CLIENT_PORTAL_SECRET=""

# Build/runtime behavior
# Keep true to avoid DB reads for system settings during production build.
SKIP_SYSTEM_SETTINGS_DB_DURING_BUILD="true"
# App log level: debug|info|warn|error.
LOG_LEVEL="info"
# Papertrail hostname (leave empty to disable Papertrail shipping).
PAPERTRAIL_HOST=""
# Papertrail UDP syslog port.
PAPERTRAIL_PORT=""
# Minimum log level forwarded to Papertrail: debug|info|warn|error.
PAPERTRAIL_MIN_LEVEL="info"
# App name tag used in Papertrail syslog messages.
PAPERTRAIL_APP_NAME="vriksham-jobs"
# Syslog facility code (0-23). Default local0=16.
PAPERTRAIL_FACILITY="16"
# Default API error-log retention in days (Admin UI can override in DB).
API_ERROR_LOG_RETENTION_DAYS="90"

# Auth and session controls
# Temporary default password marker used by password-change enforcement.
AUTH_DEFAULT_PASSWORD="Welcome123!"
# Session lifetime in seconds (default 12 hours).
AUTH_SESSION_MAX_AGE_SECONDS="43200"
# Max failed logins before lockout.
AUTH_LOGIN_MAX_ATTEMPTS="5"
# Lockout duration in minutes after max failed logins.
AUTH_LOGIN_LOCKOUT_MINUTES="15"
# Login endpoint requests allowed per rate-limit window.
AUTH_LOGIN_RATE_LIMIT_MAX_REQUESTS="20"
# Login endpoint rate-limit window in seconds.
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS="900"
# Password reset token time-to-live in minutes.
AUTH_PASSWORD_RESET_TOKEN_TTL_MINUTES="60"
# Forgot-password requests allowed per rate-limit window.
AUTH_FORGOT_PASSWORD_RATE_LIMIT_MAX_REQUESTS="6"
# Forgot-password window in seconds.
AUTH_FORGOT_PASSWORD_RATE_LIMIT_WINDOW_SECONDS="900"
# Reset-password submissions allowed per rate-limit window.
AUTH_RESET_PASSWORD_RATE_LIMIT_MAX_REQUESTS="10"
# Reset-password window in seconds.
AUTH_RESET_PASSWORD_RATE_LIMIT_WINDOW_SECONDS="900"

# Rate-limit and abuse controls
# Optional secret used to salt request-throttle IP hashing.
# If empty, falls back to AUTH_SESSION_SECRET.
RATE_LIMIT_SECRET=""
# Public careers apply requests allowed per window.
CAREERS_APPLY_RATE_LIMIT_MAX_REQUESTS="6"
# Public careers apply window in seconds.
CAREERS_APPLY_RATE_LIMIT_WINDOW_SECONDS="900"
# Minimum form fill seconds accepted for public apply anti-bot checks.
CAREERS_APPLY_MIN_FORM_FILL_SECONDS="2"
# Lookup/typeahead requests allowed per window.
LOOKUP_RATE_LIMIT_MAX_REQUESTS="80"
# Lookup/typeahead rate-limit window in seconds.
LOOKUP_RATE_LIMIT_WINDOW_SECONDS="60"
# Global search requests allowed per window.
GLOBAL_SEARCH_RATE_LIMIT_MAX_REQUESTS="30"
# Global search rate-limit window in seconds.
GLOBAL_SEARCH_RATE_LIMIT_WINDOW_SECONDS="60"
# Candidate matching endpoint requests allowed per window.
CANDIDATE_MATCH_RATE_LIMIT_MAX_REQUESTS="20"
# Candidate matching window in seconds.
CANDIDATE_MATCH_RATE_LIMIT_WINDOW_SECONDS="60"
# Job-order matching endpoint requests allowed per window.
JOB_ORDER_MATCH_RATE_LIMIT_MAX_REQUESTS="20"
# Job-order matching window in seconds.
JOB_ORDER_MATCH_RATE_LIMIT_WINDOW_SECONDS="60"
# Mutation endpoint requests allowed per window.
MUTATION_RATE_LIMIT_MAX_REQUESTS="120"
# Mutation endpoint window in seconds.
MUTATION_RATE_LIMIT_WINDOW_SECONDS="60"
# Resume parsing requests allowed per window.
RESUME_PARSE_RATE_LIMIT_MAX_REQUESTS="30"
# Resume parsing window in seconds.
RESUME_PARSE_RATE_LIMIT_WINDOW_SECONDS="600"
# Global throttle cleanup pass interval in seconds.
REQUEST_THROTTLE_GLOBAL_CLEANUP_INTERVAL_SECONDS="300"
# Global throttle cleanup threshold floor in seconds.
REQUEST_THROTTLE_GLOBAL_CLEANUP_SECONDS="3600"

# Backups and operational alerts
# Directory used by backup scripts and diagnostics checks.
DB_BACKUP_DIR=".backups"
# Scheduled backup retention in days.
DB_BACKUP_RETENTION_DAYS="14"
# Optional shared secret for the Postmark inbound webhook endpoint.
# If set, provide it as ?secret=... on the webhook URL or via x-webhook-secret.
POSTMARK_INBOUND_WEBHOOK_SECRET=""
# Error alert webhook URL (leave empty to disable).
ERROR_ALERT_WEBHOOK_URL=""
# Lowest log severity that triggers error alerts.
ERROR_ALERT_MIN_LEVEL="error"
# Error-alert cooldown in seconds to reduce duplicate alert noise.
ERROR_ALERT_COOLDOWN_SECONDS="300"
# Source label included in error alert payloads.
ERROR_ALERT_SOURCE="vriksham-jobs"
# Health alert webhook URL (leave empty to disable).
HEALTH_ALERT_WEBHOOK_URL=""
# Source label included in health alert payloads.
HEALTH_ALERT_SOURCE="vriksham-jobs"

# CI/preflight behavior
# Skip DB connectivity test in preflight checks.
PREFLIGHT_SKIP_DB_CONNECTIVITY="false"
# DB connectivity retries in preflight checks.
PREFLIGHT_DB_RETRIES="1"
# Delay between preflight DB retries in ms.
PREFLIGHT_DB_RETRY_DELAY_MS="2500"

# Demo reset loop scheduler
# Enables demo-only UX behavior:
# - Admin system settings remain visible but read-only
# - Login screen shows demo credentials
DEMO_MODE="false"
# Demo login credentials displayed on login when DEMO_MODE=true.
DEMO_ADMIN_EMAIL="admin@demoats.com"
DEMO_RECRUITER_EMAIL="recruiter@demoats.com"
DEMO_LOGIN_PASSWORD="Welcome123!"
# Interval in minutes for npm run demo:reset:loop.
DEMO_RESET_INTERVAL_MINUTES="360"
# Whether demo:reset:loop runs a reset immediately when the process starts.
DEMO_RESET_RUN_ON_START="true"
# Reset mode used by demo:reset:loop: "seed" (default) or "full".
DEMO_RESET_MODE="seed"

# Bootstrap default admin provisioning
# If enabled (or if email/password are both set), bootstrap creates an initial admin
# when the database has zero users.
BOOTSTRAP_ADMIN_ENABLED="false"
BOOTSTRAP_ADMIN_FIRST_NAME="System"
BOOTSTRAP_ADMIN_LAST_NAME="Administrator"
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""

# Hosted billing (base plan + per-user seat quantity)
# Enable Stripe seat synchronization from admin/user lifecycle actions.
BILLING_ENABLED="false"
# Billing provider currently supported: stripe
BILLING_PROVIDER="stripe"
# Stripe API secret key for billing sync operations.
BILLING_STRIPE_SECRET_KEY=""
# Stripe customer id for this hosted tenant/account (ex: cus_***).
BILLING_STRIPE_CUSTOMER_ID=""
# Stripe subscription id that includes base + seat items (ex: sub_***).
BILLING_STRIPE_SUBSCRIPTION_ID=""
# Stripe price id for the base fixed monthly charge (ex: price_***).
BILLING_BASE_PRICE_ID=""
# Stripe price id for per-seat monthly charge (ex: price_***).
BILLING_SEAT_PRICE_ID=""
# Optional explicit subscription item id for seat quantity updates (ex: si_***).
BILLING_STRIPE_SEAT_SUBSCRIPTION_ITEM_ID=""
# Optional explicit subscription item id for the base charge.
BILLING_STRIPE_BASE_SUBSCRIPTION_ITEM_ID=""
# Stripe proration behavior on seat updates: create_prorations|always_invoice|none
BILLING_STRIPE_PRORATION_BEHAVIOR="create_prorations"
# Fallback display currency when Stripe pricing data is unavailable.
BILLING_CURRENCY="usd"

# AI and file storage fallback behavior
# OpenAI model used for resume parsing/enrichment when OpenAI is configured.
OPENAI_RESUME_MODEL="gpt-4o-mini"
# Local fallback storage root for file uploads when object storage is unavailable.
# Empty uses "<project>/.local-storage".
LOCAL_STORAGE_ROOT=""

# Email safety routing
# Keep true in non-production to redirect all outbound email to one recipient.
EMAIL_TEST_MODE="true"
# Recipient that receives all email while EMAIL_TEST_MODE=true.
EMAIL_TEST_RECIPIENT=""

# Legacy URL fallbacks (optional, normally not needed)
# APP_BASE_URL=""
# NEXT_PUBLIC_APP_URL=""
